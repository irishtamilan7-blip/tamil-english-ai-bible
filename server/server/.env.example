# Server
PORT=5001
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/biblevoice

# Auth
JWT_SECRET=your_jwt_secret_minimum_32_chars_here
JWT_EXPIRES_IN=30d

# Groq AI (Bible AI chat, verse explanation, cross-references)
# Get free key at https://console.groq.com
GROQ_API_KEY=gsk_...

# Email (Nodemailer - use Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_16_chars
ADMIN_EMAIL=admin@bibleapp.com

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000
