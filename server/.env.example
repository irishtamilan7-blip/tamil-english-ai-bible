# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/biblevoice

# Auth
JWT_SECRET=your_jwt_secret_minimum_32_chars_here
JWT_EXPIRES_IN=30d

# OpenAI (Voice + AI features)
OPENAI_API_KEY=sk-...

# Email (Nodemailer - use Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_16_chars
ADMIN_EMAIL=admin@bibleapp.com

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000
